{
  "name": "treefork",
  "version": "0.0.3",
  "description": "AI agent workspace isolation using git worktrees",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kamalnrf/treefork.git"
  },
  "bin": {
    "treefork": "./dist/src/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "cli": "bun run src/cli.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./index.ts ./src/cli.ts --outdir ./dist --target node --format esm --splitting",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "citty": "^0.2.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
